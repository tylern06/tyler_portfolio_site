{
  "name": "next_scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "generate:post": "npx ts-node --esm scripts/generate-post.ts",
    "scheduler": "node scripts/scheduler.js",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:view": "ts-node -P tsconfig.seed.json scripts/view-posts.ts",
    "docker:postgres:start": "docker-compose up -d postgres",
    "docker:postgres:stop": "docker-compose stop postgres",
    "docker:postgres:down": "docker-compose down",
    "docker:postgres:logs": "docker-compose logs -f postgres",
    "docker:postgres:clean": "docker-compose down -v"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
